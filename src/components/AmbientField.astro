---
/**
 * Fixed, page-wide ambient scatter field behind all content.
 * See scripts/ambient.ts for the rationale and tuning knobs.
 */
---

<canvas id="ambient" aria-hidden="true"></canvas>

<style>
  #ambient {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;          /* behind content, above the body background */
    pointer-events: none;
    opacity: 0;
    transition: opacity 1.2s ease;
  }
  #ambient.ready { opacity: 1; }

  @media (prefers-reduced-motion: reduce) {
    #ambient { transition: none; }
  }
</style>

<script>
  import { initAmbient } from '../scripts/ambient';

  // Defer past first paint so hero text is never blocked.
  requestAnimationFrame(() => {
    const canvas = document.getElementById('ambient') as HTMLCanvasElement | null;
    if (canvas) initAmbient(canvas);
  });
</script>
