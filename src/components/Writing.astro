---
import { getCollection } from 'astro:content';
import SectionHeader from './SectionHeader.astro';

// Per spec: hide the whole section if no non-draft posts. Sidebar already
// mirrors this — see Sidebar.astro's showWriting logic.
const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const hasPosts = posts.length > 0;

function fmtDate(d: Date) {
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${y}·${m}·${day}`;
}
---

{hasPosts && (
  <section id="writing" class="section reveal">
    <SectionHeader number="05" title="Writing" meta={`[ n=${posts.length} ]`} />

    <ul class="list">
      {posts.map((post) => (
        <li class="item">
          <a href={`/writing/${post.slug}/`}>
            <time class="date">{fmtDate(post.data.date)}</time>
            <span class="title">{post.data.title}</span>
            <span class="tags">
              {post.data.tags.map((t) => <span class="tag">#{t}</span>)}
            </span>
            <span class="arrow" aria-hidden="true">↗</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--hairline);
  }
  .item { border-bottom: 1px solid var(--hairline); }

  .item a {
    display: grid;
    grid-template-columns: 120px 1fr auto 20px;
    gap: 16px;
    align-items: baseline;
    padding: 18px 0;
    text-decoration: none;
    color: inherit;
    transition: padding-left var(--dur-base) var(--ease-out);
  }
  .item a:hover {
    padding-left: 8px;
  }
  .item a:hover .title { color: var(--text); }
  .item a:hover .arrow { color: var(--accent); }

  .date {
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    color: var(--text-aux);
    letter-spacing: 0.06em;
    font-variant-numeric: tabular-nums;
  }
  .title {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    color: var(--text-dim);
    transition: color var(--dur-base);
  }
  .tags {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    color: var(--text-aux);
    display: flex;
    gap: 8px;
  }
  .tag::before { content: ''; }
  .arrow {
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    color: var(--text-aux);
    transition: color var(--dur-base), transform var(--dur-base) var(--ease-out);
  }

  @media (max-width: 640px) {
    .item a {
      grid-template-columns: 90px 1fr 20px;
      gap: 12px;
    }
    .tags { display: none; }
  }
</style>
